---
import "../styles/global.css";
import { Moon, Sun, Braces, Search, Rss } from "@lucide/astro";
import { ClientRouter } from "astro:transitions";

const isOnCurrentPath = (path: string) => {
    return Astro.url.pathname === path;
};
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <ClientRouter />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Serene Ink</title>
        <link
            rel="alternate"
            type="application/rss+xml"
            title="Serene Ink"
            href={new URL("feed.xml", Astro.url.origin)}
        />
        <script is:inline>
            const setDarkMode = () => {
                const theme = (() => {
                    if (
                        typeof localStorage !== "undefined" &&
                        localStorage.getItem("theme")
                    ) {
                        return localStorage.getItem("theme");
                    }
                    if (
                        window.matchMedia("(prefers-color-scheme: dark)")
                            .matches
                    ) {
                        return "dark";
                    }
                    return "light";
                })();
                if (theme === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    document.documentElement.classList.add("dark");
                }
            };
            setDarkMode();
            document.addEventListener("astro:after-swap", setDarkMode);
        </script>
    </head>
    <body class="max-w-page mx-auto">
        <nav class="px-5 lg:px-0 py-5 flex justify-between">
            <Braces />

            <ul class="flex items-center gap-4">
                <li>
                    <a href="/" class={isOnCurrentPath("/") ? "active" : ""}
                        ><span class={isOnCurrentPath("/") ? "" : "nav-link"}
                            >Writing</span
                        ></a
                    >
                </li>
                <li>
                    <a
                        href="/about"
                        class={isOnCurrentPath("/about") ? "active" : ""}
                        ><span
                            class={isOnCurrentPath("/about") ? "" : "nav-link"}
                            >About</span
                        ></a
                    >
                </li>
                <li>
                    <button
                        id="theme-toggle"
                        type="button"
                        aria-label="Toggle dark mode"
                    >
                        <Moon class="block dark:hidden" size={16} />
                        <Sun class="hidden dark:block" size={16} />
                    </button>
                </li>
                <li>
                    <a href="/feed.xml" aria-label="RSS feed">
                        <Rss size={16} />
                    </a>
                </li>
                <li>
                    <button type="button" aria-label="Open search">
                        <Search size={16} />
                    </button>
                </li>
            </ul>
        </nav>
        <slot />
        <div
            id="cursor"
            class="bg-primary mix-blend-hard-light opacity-0 size-3 rounded-full pointer-events-none z-9999 fixed top-0 left-0"
            transition:persist
        >
        </div>
        <script is:inline src="/scripts/cursor.js"></script>
        <script>
            let onThemeToggleClick: ((e: MouseEvent) => void) | null = null;

            document.addEventListener("astro:before-swap", () => {
                const themeToggle = document.getElementById("theme-toggle");
                if (onThemeToggleClick && themeToggle) {
                    themeToggle.removeEventListener(
                        "click",
                        onThemeToggleClick,
                    );
                    onThemeToggleClick = null;
                }
            });

            document.addEventListener("astro:page-load", () => {
                const themeToggle = document.getElementById("theme-toggle");
                if (!themeToggle) return;

                onThemeToggleClick = (event: MouseEvent) => {
                    const isDark =
                        document.documentElement.classList.contains("dark");

                    const toggleTheme = () => {
                        if (isDark) {
                            document.documentElement.classList.remove("dark");
                            localStorage.setItem("theme", "light");
                        } else {
                            document.documentElement.classList.add("dark");
                            localStorage.setItem("theme", "dark");
                        }
                    };

                    if (!document.startViewTransition) {
                        toggleTheme();
                        return;
                    }

                    const x = event.clientX;
                    const y = event.clientY;
                    // compute radius required to cover the entire viewport
                    // finds distance from click point to the farthest corner;
                    // hypot for calculating straight line distance
                    const endRadius = Math.hypot(
                        Math.max(x, innerWidth - x), // furthest horiz dist
                        Math.max(y, innerHeight - y), // furthest vert dist
                    );

                    document.documentElement.classList.add("theme-transition");

                    const transition = document.startViewTransition(() => {
                        toggleTheme();
                    });

                    transition.ready.then(() => {
                        const clipPath = [
                            `circle(0px at ${x}px ${y}px)`,
                            `circle(${endRadius}px at ${x}px ${y}px)`,
                        ];

                        document.documentElement.animate(
                            {
                                clipPath: clipPath,
                            },
                            {
                                duration: 500,
                                easing: "ease-in-out",
                                // targets the "new" snapshot layer created by the transition
                                pseudoElement: "::view-transition-new(root)",
                            },
                        );
                    });

                    // cleanup
                    transition.finished.finally(() => {
                        document.documentElement.classList.remove(
                            "theme-transition",
                        );
                    });
                };

                themeToggle.addEventListener("click", onThemeToggleClick);
            });
        </script>
    </body>
</html>
