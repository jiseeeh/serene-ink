---
import { getCollection } from "astro:content";
import Badge from "./ui/Badge.astro";

const entries = await getCollection("post");
const posts = entries
    .map((entry) => ({
        id: entry.id,
        slug: entry.id,
        readTime: Math.max(1, Math.ceil(entry.body!.split(/\s+/).length / 200)),
        ...entry.data,
    }))
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

type MappedPost = (typeof posts)[number];

const monthName = (n: number) =>
    new Date(2000, n - 1).toLocaleString("en", { month: "short" });

const dateRange = (posts: MappedPost[]) => {
    const days = posts.map((p) => Number(p.date.split("/")[1]));
    return days.length === 1
        ? String(days[0])
        : `${Math.min(...days)} - ${Math.max(...days)}`;
};

const grouped = posts.reduce(
    (acc, post) => {
        const [m, , y] = post.date.split("/");
        const month = monthName(Number(m));
        if (!acc[y]) acc[y] = {};
        if (!acc[y][month]) acc[y][month] = [];
        acc[y][month].push(post);
        return acc;
    },
    {} as Record<string, Record<string, MappedPost[]>>,
);
---

<main class="page">
    <span class="uppercase text-primary font-medium tracking-widest"
        >notebook</span
    >

    <h1 class="text-4xl mt-10">Writing</h1>
    <p class="text-lg max-w-122 text-muted-foreground">
        Thoughts on systems, craft, and the quiet details of building things
        well.
    </p>

    <section class="mt-20 my-5">
        {
            Object.keys(grouped)
                .sort((a, b) => Number(b) - Number(a))
                .map((year) => (
                <section>
                    <h2 class="text-2xl">{year}</h2>
                    {Object.entries(grouped[year]).map(([month, posts]) => (
                        <section>
                            <h3 class="text-sm text-muted-foreground uppercase font-medium tracking-widest">
                                {month} {dateRange(posts)}
                            </h3>
                            <hr class="mt-2" />
                            <section class="flex flex-col gap-3 my-5">
                                {posts.map((post) => {
                                    return (
                                        <section class="flex flex-col gap-2 group hover:bg-muted px-3 py-8 rounded-md transition-all duration-300">
                                            <div class="flex flex-col md:flex-row gap-2 md:justify-between md:items-start">
                                                <a href={`/posts/${post.slug}`}>
                                                    <h2 class="text-2xl group-hover:text-primary leading-tight">
                                                        {post.title}
                                                    </h2>
                                                </a>
                                                <span class="text-muted-foreground text-xs shrink-0 whitespace-nowrap md:mt-1 md:text-right text-left mt-1">
                                                    {post.readTime} min read
                                                </span>
                                            </div>
                                            <p class="text-muted-foreground">
                                                {post.frontmatter}
                                            </p>
                                            <section class="flex gap-2 flex-wrap">
                                                {post.tags.map((tag) => {
                                                    return (
                                                        <Badge content={tag} />
                                                    );
                                                })}
                                            </section>
                                        </section>
                                    );
                                })}
                            </section>
                        </section>
                    ))}
                </section>
            ))
        }
    </section>
</main>
