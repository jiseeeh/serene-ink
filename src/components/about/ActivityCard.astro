---
interface Props {
    imageSrc: string;
    imageAlt: string;
    label: string;
    title: string;
    subtitle: string;
}

const { imageSrc, imageAlt, label, title, subtitle } = Astro.props;
---

<!-- TODO: use Image component -->
<!-- TODO: move images to src -->
<section
    class="h-44 w-full relative flex flex-col rounded-lg border overflow-hidden group"
>
    <img
        src={imageSrc}
        alt={imageAlt}
        class="object-cover absolute size-full mask-[linear-gradient(to_bottom,black,transparent_80%)] group-hover:scale-110 transition-transform ease-in-out duration-400"
    />
    <section class="flex flex-col p-4 mt-auto relative z-10">
        <span class="text-[8px] uppercase text-muted-foreground">{label}</span>
        <span
            class="font-bold text-md group-hover:text-accent transition-colors ease-in-out duration-400"
            >{title}</span
        >
        <span class="text-xs opacity-60 text-muted-foreground">{subtitle}</span>
    </section>
</section>
